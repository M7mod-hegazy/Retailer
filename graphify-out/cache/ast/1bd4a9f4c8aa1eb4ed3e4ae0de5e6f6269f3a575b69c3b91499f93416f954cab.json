060c \u0648\u062a\u0623\u0643\u062f \u0645\u0646 \u0639\u062f\u0645 \u062a\u0633\u062c\u064a\u0644 \u062a\u062d\u0635\u064a\u0644 \u0643\u0627\u0634 \u0643\u0628\u0646\u0643 \u0623\u0648 \u0627\u0644\u0639\u0643\u0633.\",\r\n    ];\r\n    return [\r\n      `\u064a\u0648\u062c\u062f \u0632\u064a\u0627\u062f\u0629 ${abs} \u062c.\u0645. \u0627\u0628\u062d\u062b \u0639\u0646 \u0625\u064a\u0631\u0627\u062f \u0623\u0648 \u062a\u062d\u0635\u064a\u0644 \u0639\u0645\u064a\u0644 \u063a\u064a\u0631 \u0645\u0633\u062c\u0644.`,\r\n      \"\u0631\u0627\u062c\u0639 \u0645\u0631\u062a\u062c\u0639\u0627\u062a \u0627\u0644\u0645\u0628\u064a\u0639\u0627\u062a \u0644\u0623\u0646 \u0623\u064a \u0631\u062f \u0646\u0642\u062f\u064a \u0646\u0627\u0642\u0635 \u0627\u0644\u062a\u0633\u062c\u064a\u0644 \u064a\u0638\u0647\u0631 \u0643\u0632\u064a\u0627\u062f\u0629 \u0641\u064a \u0627\u0644\u062f\u0631\u062c.\",\r\n    ];\r\n  })", "is_member_call": false, "source_file": "D:\\code\\retailer\\client\\src\\pages\\pos\\DailyTreasuryPage.jsx", "source_location": "L328"}, {"caller_nid": "pos_dailytreasurypage_dailytreasurypage", "callee": "(() => {\r\n                    // Check if this is the latest closed day (no later session exists)\r\n                    const hasLaterSession = pastSessions.some(s => s.date > date);\r\n                    const canReopen = isToday || !hasLaterSession;\r\n                    return canReopen ? (\r\n                      <div className=\"flex items-center gap-2\">\r\n                        <input\r\n                          value={reopenReason}\r\n                          onChange={(e) => setReopenReason(e.target.value)}\r\n                          placeholder=\"\u0633\u0628\u0628 \u0625\u0639\u0627\u062f\u0629 \u0627\u0644\u0641\u062a\u062d\"\r\n                          className=\"h-9 w-48 rounded-xl border border-blue-200 bg-white px-3 text-[11px] font-bold outline-none focus:border-blue-500\"\r\n                        />\r\n                        <button\r\n                          onClick={reopenDay}\r\n                          disabled={reopening || !reopenReason.trim()}\r\n                          className=\"flex h-9 items-center gap-1.5 rounded-xl bg-blue-700 px-3 text-[11px] font-black text-white hover:bg-blue-800 disabled:opacity-40\"\r\n                        >\r\n                          <RotateCcw className=\"h-3.5 w-3.5\" /> \u0625\u0639\u0627\u062f\u0629 \u0641\u062a\u062d\r\n                        </button>\r\n                      </div>\r\n                    ) : (\r\n                      <span className=\"text-[11px] font-bold text-blue-600\">\u0644\u0627 \u064a\u0645\u0643\u0646 \u0625\u0639\u0627\u062f\u0629 \u0641\u062a\u062d \u0647\u0630\u0627 \u0627\u0644\u064a\u0648\u0645 \u0644\u0623\u0646 \u0647\u0646\u0627\u0643 \u0623\u064a\u0627\u0645 \u0623\u062d\u062f\u062b \u0645\u0648\u062c\u0648\u062f\u0629.</span>\r\n                    );\r\n                  })", "is_member_call": false, "source_file": "D:\\code\\retailer\\client\\src\\pages\\pos\\DailyTreasuryPage.jsx", "source_location": "L588"}, {"caller_nid": "pos_dailytreasurypage_dailytreasurypage", "callee": "map", "is_member_call": true, "source_file": "D:\\code\\retailer\\client\\src\\pages\\pos\\DailyTreasuryPage.jsx", "source_location": "L683"}, {"caller_nid": "pos_dailytreasurypage_dailytreasurypage", "callee": "map", "is_member_call": true, "source_file": "D:\\code\\retailer\\client\\src\\pages\\pos\\DailyTreasuryPage.jsx", "source_location": "L779"}, {"caller_nid": "pos_dailytreasurypage_dailytreasurypage", "callee": "map", "is_member_call": true, "source_file": "D:\\code\\retailer\\client\\src\\pages\\pos\\DailyTreasuryPage.jsx", "source_location": "L806"}, {"caller_nid": "pos_dailytreasurypage_dailytreasurypage", "callee": "map", "is_member_call": true, "source_file": "D:\\code\\retailer\\client\\src\\pages\\pos\\DailyTreasuryPage.jsx", "source_location": "L827"}, {"caller_nid": "pos_dailytreasurypage_dailytreasurypage", 
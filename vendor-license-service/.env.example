PORT=5050
HOST=127.0.0.1
VENDOR_DB_PATH=./data/vendor-licenses.db
VENDOR_ISSUER=ElHegazi-Licensing
VENDOR_ADMIN_API_KEY=change_me_admin
VENDOR_APP_API_KEY=change_me_app
VENDOR_PRIVATE_KEY_PEM=
VENDOR_PUBLIC_KEY_PEM=
ACTIVATION_REFRESH_HOURS=24

# Optional help-assistant AI fallback (provider-agnostic, OpenAI-compatible).
# Leave AI_BASE_URL / AI_API_KEY / AI_MODEL empty to keep it OFF (default).
# Works with OpenRouter (incl. free models), Groq, Together, Ollama, OpenAI, etc.
AI_PROVIDER=openai-compatible
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
# AI_SYSTEM_PROMPT=   # optional Arabic system-prompt override
AI_TIMEOUT_MS=20000
AI_DAILY_LIMIT=50

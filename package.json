{
  "name": "retailer",
  "version": "1.1.5",
  "main": "electron/main.js",
  "scripts": {
    "dev": "npm run kill:retailer-processes && concurrently -k \"npm:dev:server\" \"npm:dev:client\" \"npm:dev:electron\" \"npm:dev:vendor\"",
    "dev:web": "npm run kill:retailer-processes && concurrently -k \"npm:dev:server\" \"npm:dev:web:client\"",
    "dev:web:client": "npm run dev --prefix client -- --host 127.0.0.1 --port 5173 --strictPort --open",
    "dev:vendor": "node vendor-license-service/src/index.js",
    "dev:client": "npm run dev --prefix client -- --host 127.0.0.1 --port 5173 --strictPort",
    "dev:server": "npm run electron:rebuild && npm run dev --prefix server",
    "dev:server:fast": "npm run dev --prefix server",
    "dev:web:fast": "npm run kill:retailer-processes && concurrently -k \"npm:dev:server:fast\" \"npm:dev:web:client\"",
    "dev:electron": "wait-on http://127.0.0.1:5173 tcp:5000 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "start": "npm run kill:retailer-processes && npm run electron:rebuild && npm run build --prefix client && electron .",
    "start:quick": "npm run build --prefix client && electron .",
    "build": "npm run build --prefix client",
    "dist": "node ./electron/scripts/build-dist.js",
    "dist:x64": "node ./electron/scripts/build-dist.js --x64-only",
    "dist:win11": "npm run electron:rebuild && electron-builder --win --config electron-builder-x64-win11.yml",
    "dist:win7": "node ./electron/scripts/build-win7-test.js --arch=x64",
    "dist:win7:ia32": "node ./electron/scripts/build-win7-test.js --arch=ia32",
    "dist:win7:test": "node ./electron/scripts/build-win7-test.js",
    "publish:win7": "node ./electron/scripts/publish-release.js",
    "publish:ia32": "node ./electron/scripts/publish-ia32-only.js",
    "release": "node ./electron/scripts/build-dist.js --publish",
    "release:win11": "npm run build && npm run electron:rebuild && electron-builder --win --config electron-builder-x64-win11.yml --publish always",
    "windows:configure-users": "powershell -NoProfile -ExecutionPolicy Bypass -File ./electron/scripts/configure-local-users.ps1",
    "windows:harden-acl": "powershell -NoProfile -ExecutionPolicy Bypass -File ./electron/scripts/harden-windows-policy.ps1",
    "bootstrap": "npm install --workspaces",
    "kill:retailer-processes": "node ./electron/scripts/kill-retailer-processes.js",
    "installer:art": "node ./electron/scripts/make-installer-art.js",
    "license:keygen": "node tools/license-signer/keygen.js",
    "sign": "node tools/license-signer/sign-license.js",
    "sign:gui": "cross-env ELECTRON_RUN_AS_NODE= electron tools/license-signer/signer-gui/main.js",
    "node:rebuild": "npm rebuild better-sqlite3",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3 -a x64",
    "postinstall": "electron-rebuild -f -w better-sqlite3 -a x64"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/M7mod-hegazy/Retailer.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/M7mod-hegazy/Retailer/issues"
  },
  "homepage": "https://github.com/M7mod-hegazy/Retailer#readme",
  "description": "",
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "docx": "^9.6.1",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^29.4.6",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.5"
  },
  "private": true,
  "workspaces": [
    "client",
    "server"
  ]
}
